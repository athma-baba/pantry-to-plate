rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User documents: only the authenticated user can read/update their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Disallow clients from writing `entitlements` (server-only).
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['entitlements']);
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['entitlements']);
      allow delete: if false; // forbid client deletes of user documents
    }

    // Usage counters: only Cloud Functions should write these (clients should not write)
    match /users/{userId}/usage/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // writes must come from trusted server-side functions
    }

    // Households: read if member, write if admin (example schema)
    match /households/{householdId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow write: if request.auth != null && request.auth.uid in resource.data.admins;
    }

    // By default deny other access
  }
}
